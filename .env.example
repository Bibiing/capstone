# =============================================================================
# WAZUH CONNECTION
# =============================================================================
# Wazuh Manager REST API
WAZUH_API_URL=url:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=CHANGE_ME_STRONG_PASSWORD
WAZUH_API_AUTH_PATH=/security/user/authenticate
WAZUH_API_AUTH_USE_RAW=true
WAZUH_API_AUTO_PORT_DISCOVERY=true

# Wazuh Indexer / OpenSearch (different credentials from above)
WAZUH_INDEXER_URL=url:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# SSL: Set to false for self-signed lab certificates
WAZUH_VERIFY_SSL=false

# Request timeout in seconds
WAZUH_API_TIMEOUT=30

# Max retry attempts on transient failures
WAZUH_MAX_RETRIES=3

# =============================================================================
# DATABASE
# =============================================================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://capstone:capstone_dev@localhost:5432/risk_scoring

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# PostgreSQL container settings (used by docker-compose only)
POSTGRES_USER=capstone
POSTGRES_PASSWORD=capstone_dev
POSTGRES_DB=risk_scoring

# =============================================================================
# SCORING ENGINE
# =============================================================================
# How often (in hours) the scoring cycle runs
SCORING_INTERVAL_HOURS=1

# How far back (in hours) to look for Wazuh alerts per scoring cycle
ALERT_LOOKBACK_HOURS=1

# Time decay factor α: 0.5 = 50% of T_prev carries forward each period
DECAY_FACTOR=0.5

# w1 + w2 MUST sum to 1.0
WEIGHT_VULNERABILITY=0.3
WEIGHT_THREAT=0.7

# =============================================================================
# REST API (Sprint 3-4)
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_ENVIRONMENT=development
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_HEX

# =============================================================================
# JWT & AUTHENTICATION
# =============================================================================
# JWT algorithm for token signing
JWT_ALGORITHM=HS256

# Token expiration time (hours)
JWT_EXPIRATION_HOURS=24

# OTP code expiration time (minutes)
OTP_EXPIRATION_MINUTES=15

# Max failed OTP attempts before lockout
OTP_MAX_ATTEMPTS=5

# =============================================================================
# pgAdmin (Development only — used with: docker compose --profile dev up)
# =============================================================================
PGADMIN_EMAIL=admin@localhost.dev
PGADMIN_PASSWORD=admin_dev
